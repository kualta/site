---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CornersScope from "@/components/CornersScope.astro";
import Sticker from "@/components/Sticker.astro";
import { EmailSubscription } from "@/components/EmailSubscription.tsx";
---
<BaseLayout title="join" description="join kunet">
  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-4 p-10 px-16 mb-32 relative">
      <CornersScope top_left={false} bottom_right={false} />
      <h1 class="text-3xl font-bold text-center">Subscribe</h1>
      <EmailSubscription client:load />
      <p class="text-lg sm:text-xl text-center p-4 pt-0">
        Kurier will deliver latest articles <br /> right into your mailbox.
      </p>
      <Sticker
        name="kurier"
        class="hidden sm:flex absolute w-32 h-32 md:w-48 md:h-48 -right-10 -bottom-10 md:-right-24 md:-bottom-24"
      />
    </div>
  </div>
</BaseLayout>
